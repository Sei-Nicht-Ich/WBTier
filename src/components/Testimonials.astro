		  <span class="text-olive text-xl">★</span>
		  <span class="text-olive text-xl">★</span>
		  <span class="text-olive text-xl">★</span>
		  <span class="text-olive text-xl">★</span>
		</div>

		<!-- Quote -->
		<p class="text-charcoal/80 leading-relaxed mb-6 italic">
		  "Professionell, einfühlsam und mit viel Geduld. Unsere ängstliche 
		  Katze hat endlich wieder Vertrauen gefasst. Eine absolute Empfehlung!"
		</p>

		<!-- Author -->
		<div class="flex items-center gap-3">
		  <div class="w-12 h-12 bg-sage rounded-full flex items-center justify-center">
