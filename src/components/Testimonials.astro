---
// Testimonials Section - Kundenstimmen
---

<section class="section-padding bg-gradient-to-br from-sage/20 via-cream to-olive/10">
  <div class="max-w-7xl mx-auto">

	<!-- Section Header -->
	<div class="text-center mb-16">
	  <p class="text-olive uppercase tracking-widest text-sm font-medium mb-4">
		Kundenstimmen
	  </p>
	  <h2 class="font-heading text-4xl md:text-5xl text-charcoal mb-6">
		Was Kunden sagen
	  </h2>
	  <p class="text-charcoal/70 text-lg max-w-2xl mx-auto">
		Erfahrungen von zufriedenen Tierbesitzern und ihren vierbeinigen Begleitern
	  </p>
	</div>

	<!-- Testimonials Grid -->
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

	  <!-- Testimonial 1 -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-smooth">
		<!-- Stars -->
		<div class="flex gap-1 mb-4">
		  <span class="text-olive text-xl">★</span>
		  <span class="text-olive text-xl">★</span>
		  <span class="text-olive text-xl">★</span>
		  <span class="text-olive text-xl">★</span>
		  <span class="text-olive text-xl">★</span>
		</div>

		<!-- Quote -->
		<p class="text-charcoal/80 leading-relaxed mb-6 italic">
		  "Nach nur wenigen Wochen hat sich das Verhalten unseres Hundes 
		  komplett verändert. Die Trainingsmethoden sind liebevoll und 
		  effektiv. Wir sind unglaublich dankbar!"
		</p>

		<!-- Author -->
		<div class="flex items-center gap-3">
		  <div class="w-12 h-12 bg-sage rounded-full flex items-center justify-center">
			<span class="text-xl">🐕</span>
		  </div>
		  <div>
			<p class="font-medium text-charcoal">Sarah M.</p>
			<p class="text-sm text-charcoal/60">mit Labrador Max</p>
		  </div>
		</div>
	  </div>

	  <!-- Testimonial 2 -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-smooth">
		<!-- Stars -->
		<div class="flex gap-1 mb-4">
