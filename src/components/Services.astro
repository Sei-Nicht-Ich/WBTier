---
// Services Section - Leistungsübersicht
---

<section id="services" class="section-padding bg-sage/20">
  <div class="max-w-7xl mx-auto">

	<!-- Section Header -->
	<div class="text-center mb-16">
	  <p class="text-olive uppercase tracking-widest text-sm font-medium mb-4">
		Meine Leistungen
	  </p>
	  <h2 class="font-heading text-4xl md:text-5xl text-charcoal mb-6">
		Wie ich Ihnen helfen kann
	  </h2>
	  <p class="text-charcoal/70 text-lg max-w-2xl mx-auto">
		Individuelle Beratung und Training für ein harmonisches Zusammenleben 
		mit Ihrem Tier
	  </p>
	</div>

	<!-- Services Grid -->
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

	  <!-- Service 1: Verhaltensanalyse -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">
		<div class="text-5xl mb-6">🔍</div>
		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Verhaltensanalyse
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Ausführliche Analyse des Verhaltens Ihres Tieres, um die Ursachen 
		  für Probleme zu identifizieren und gezielte Lösungen zu entwickeln.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Erstgespräch (90 Min.)
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Verhaltensprotokoll
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Schriftlicher Bericht
		  </li>
		</ul>
	  </div>

	  <!-- Service 2: Einzeltraining -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">
		<div class="text-5xl mb-6">🎯</div>
		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Einzeltraining
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Individuelles Training bei Ihnen zu Hause oder an einem neutralen Ort. 
		  Praktische Übungen für den Alltag mit Ihrem Tier.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Hausbesuch möglich
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Flexible Termine
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Trainingsplan inklusive
		  </li>
		</ul>
	  </div>

	  <!-- Service 3: Verhaltenstherapie -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">
		<div class="text-5xl mb-6">💚</div>
		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Verhaltenstherapie
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Langfristige Begleitung bei schwerwiegenden Verhaltensproblemen 
		  wie Aggression, Angst oder Traumata.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Mehrwöchige Programme
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Regelmäßige Kontrollen
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> E-Mail Support
		  </li>
		</ul>
	  </div>

	  <!-- Service 4: Welpenberatung -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">
		<div class="text-5xl mb-6">🐾</div>
		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Welpenberatung
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Der richtige Start ist entscheidend. Unterstützung bei der 
		  Sozialisierung und Erziehung Ihres Welpen.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Sozialisierungstipps
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Grundgehorsam
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Stubenreinheit
		  </li>
		</ul>
	  </div>

	  <!-- Service 5: Online Beratung -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">
		<div class="text-5xl mb-6">💻</div>
		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Online Beratung
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Bequem von zu Hause aus per Videocall. Ideal für erste Fragen 
		  oder als Ergänzung zum Training vor Ort.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Flexible Zeiten
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Bundesweit verfügbar
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Nachbetreuung inklusive
		  </li>
		</ul>
	  </div>

	  <!-- Service 6: Workshops -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">
		<div class="text-5xl mb-6">👥</div>
		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Workshops & Kurse
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Gruppentraining zu verschiedenen Themen. Lernen Sie gemeinsam 
		  mit anderen Tierbesitzern in entspannter Atmosphäre.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Kleine Gruppen
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Themen-Workshops
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Praxisorientiert
		  </li>
		</ul>
	  </div>

	</div>

	<!-- CTA -->
	<div class="text-center mt-16">
	  <p class="text-charcoal/70 mb-6">
		Nicht sicher, welche Leistung für Sie passend ist?
	  </p>
	  <a href="#contact" class="btn-primary inline-block">
		Kostenloses Erstgespräch vereinbaren
	  </a>
	</div>

  </div>
</section>
