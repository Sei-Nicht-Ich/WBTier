---
// Services Section - Leistungsübersicht
---

<section id="services" class="section-padding bg-sage/20 relative overflow-hidden">
  <div class="max-w-7xl mx-auto relative">

	<!-- Section Header -->
	<div class="text-center mb-16 relative">
	  <!-- Dekoratives Bild oben (nur sehr kleine Screens) -->
	  <div class="flex justify-center mb-6 sm:hidden">
		<div class="w-24 h-24 rounded-full overflow-hidden shadow-xl border-4 border-sage/40 hover:scale-110 hover:rotate-3 transition-all duration-500">
		  <img src="/animals/Murloc1.jpg" alt="Dekoratives Tierbild" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" />
		</div>
	  </div>

	  <p class="text-olive uppercase tracking-widest text-sm font-medium mb-4">
		Meine Leistungen
	  </p>
	  <h2 class="font-heading text-4xl md:text-5xl text-charcoal mb-6">
		Wie ich Ihnen helfen kann
	  </h2>
	  <p class="text-charcoal/70 text-lg max-w-2xl mx-auto mb-6 sm:mb-0">
		Individuelle Beratung und Training für ein harmonisches Zusammenleben 
		mit Ihrem Tier
	  </p>

	  <!-- Dekoratives Bild unten (nur sehr kleine Screens) -->
	  <div class="flex justify-center sm:hidden">
		<div class="w-24 h-24 rounded-full overflow-hidden shadow-xl border-4 border-sage/40 hover:scale-110 hover:rotate-3 transition-all duration-500">
		  <img src="/animals/BonitaLiegen.jpg" alt="Dekoratives Tierbild" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" />
		</div>
	  </div>

	  <!-- Seitliche Bubbles (ab sm Breakpoint) - Responsive Größen -->
	  <div class="hidden sm:block absolute -top-4 left-2 sm:left-3 md:left-4 lg:left-8 w-20 h-20 sm:w-24 sm:h-24 md:w-28 md:h-28 lg:w-40 lg:h-40 rounded-full overflow-hidden shadow-xl border-4 border-sage/40 hover:scale-110 hover:rotate-3 transition-all duration-500">
		<img src="/animals/Murloc1.jpg" alt="Dekoratives Tierbild" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" />
	  </div>
	  <div class="hidden sm:block absolute -top-4 right-2 sm:right-3 md:right-4 lg:right-8 w-20 h-20 sm:w-24 sm:h-24 md:w-28 md:h-28 lg:w-40 lg:h-40 rounded-full overflow-hidden shadow-xl border-4 border-sage/40 hover:scale-110 hover:rotate-3 transition-all duration-500">
		<img src="/animals/BonitaLiegen.jpg" alt="Dekoratives Tierbild" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" />
	  </div>
	</div>

	<!-- Services Grid -->
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative z-10">
	
	  <!-- Service 1: Trainings -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">
		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Trainings
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Individuelles Training bei Ihnen zu Hause oder an einem neutralen Ort. 
		  Praktische Übungen für den Alltag mit Ihrem Tier.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Einzel- oder Gruppentraining
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Haus- / Stallbesuch möglich
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Individuelle Trainingspläne
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Pferd, Hund
		  </li>
		</ul>
	  </div>
	  <!-- Service 2: Verhaltensanalyse -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">

		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Verhaltensanalyse
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Ausführliche Analyse des Verhaltens Ihres Tieres, um die Ursachen 
		  für Probleme zu identifizieren und gezielte Lösungen zu entwickeln.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Problemanalyse
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Individuelle Lösungsfindung
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Unterstützung bei der Umsetzung
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Pferd, Hund, Katze
		  </li>
		</ul>
	  </div>

	  <!-- Service 3: Verhaltenstherapie -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">

		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Verhaltenstherapie
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Langfristige Begleitung bei schwerwiegenden Verhaltensproblemen 
		  wie Aggression, Angst oder Traumata.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Langfristige Unterstützung
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Regelmäßige Kontrollen
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> E-Mail/WhatsApp/Telefon Support
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Pferd, Hund, Katze
		  </li>
		</ul>
	  </div>

	  <!-- Service 4: Haltungsberatung -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">

		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Haltungsberatung
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Die Haltung hat großen Einfluss auf das Verhalten und Wohlbefinden Ihres Tieres. 
		  Beratung zu artgerechter Haltung, Beschäftigung und Umweltgestaltung.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Haltungsanalyse
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Beachtung individueller Bedürfnisse
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Unterstützung bei der Umsetzung
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Pferd, Hund, Katze
		  </li>
		</ul>
	  </div>
	  <!-- Service 5: Beratung beim Tierkauf -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">

		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Beratung beim Tierkauf
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Jedes Tier hat individuelle Bedürfnisse und Charaktereigenschaften. 
		  Ich berate und begleite Sie gerne bei der Auswahl eines passenden Tieres, das zu Ihnen und Ihrem Lebensstil passt.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Bedürfnisanalyse
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Vorschläge für passende Tiere
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Begleitung von der Auswahl bis zum Einzug
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Pferd, Hund, Katze
		  </li>
		</ul>
	  </div>

	  <!-- Service 6: Online Beratung -->
	  <div class="bg-cream rounded-2xl p-8 shadow-lg card-hover">

		<h3 class="font-heading text-2xl text-charcoal mb-4">
		  Online Beratung
		</h3>
		<p class="text-charcoal/70 leading-relaxed mb-6">
		  Bequem von zu Hause aus per Videocall. Ideal für erste Fragen 
		  oder als Ergänzung zum Training vor Ort.
		</p>
		<ul class="space-y-2 text-sm text-charcoal/80">
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Flexible Zeiten
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Bundesweit verfügbar
		  </li>
		  <li class="flex items-center gap-2">
			<span class="text-olive">✓</span> Schnelle Hilfe bei akuten Problemen
		  </li>
		</ul>
	  </div>

	</div>

	<!-- CTA -->
	<div class="text-center mt-16">
	  <a href="#contact" class="btn-primary inline-block">
		Kostenloses Erstgespräch vereinbaren
	  </a>
	</div>

  </div>
</section>
