---
// Contact Form Section - Modernes Kontaktformular
---

<section id="contact" class="section-padding bg-cream relative overflow-hidden">
  <div class="max-w-7xl mx-auto relative">

	<!-- Section Header -->
	<div class="text-center mb-16 relative">
	  <!-- Dekoratives Bild oben (nur sehr kleine Screens) -->
	  <div class="flex justify-center mb-6 sm:hidden">
		<div class="w-24 h-24 rounded-full overflow-hidden shadow-xl border-4 border-sage/40 hover:scale-110 hover:rotate-3 transition-all duration-500">
		  <img src="/animals/BilboGismo.jpg" alt="Dekoratives Tierbild" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" />
		</div>
	  </div>

	  <p class="text-olive uppercase tracking-widest text-sm font-medium mb-4">
		Kontakt
	  </p>
	  <h2 class="font-heading text-4xl md:text-5xl text-charcoal mb-6">
		Lassen Sie uns sprechen
	  </h2>
	  <p class="text-charcoal/70 text-lg max-w-2xl mx-auto mb-6 sm:mb-0">
		Ich freue mich auf Ihre Nachricht und berate Sie gerne in einem 
		unverbindlichen Erstgespräch
	  </p>

	  <!-- Dekoratives Bild unten (nur sehr kleine Screens) -->
	  <div class="flex justify-center sm:hidden">
		<div class="w-24 h-24 rounded-full overflow-hidden shadow-xl border-4 border-sage/40 hover:scale-110 hover:rotate-3 transition-all duration-500">
		  <img src="/animals/Lord.jpeg" alt="Dekoratives Tierbild" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" />
		</div>
	  </div>

	  <!-- Seitliche Bubbles (ab sm Breakpoint) - Responsive Größen -->
	  <div class="hidden sm:block absolute -top-4 left-2 sm:left-3 md:left-4 lg:left-8 w-20 h-20 sm:w-24 sm:h-24 md:w-28 md:h-28 lg:w-40 lg:h-40 rounded-full overflow-hidden shadow-xl border-4 border-sage/40 hover:scale-110 hover:rotate-3 transition-all duration-500">
		<img src="/animals/BilboGismo.jpg" alt="Dekoratives Tierbild" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" />
	  </div>
	  <div class="hidden sm:block absolute -top-4 right-2 sm:right-3 md:right-4 lg:right-8 w-20 h-20 sm:w-24 sm:h-24 md:w-28 md:h-28 lg:w-40 lg:h-40 rounded-full overflow-hidden shadow-xl border-4 border-sage/40 hover:scale-110 hover:rotate-3 transition-all duration-500">
		<img src="/animals/Lord.jpeg" alt="Dekoratives Tierbild" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" />
	  </div>
	</div>

	<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 relative z-10">

	  <!-- Contact Info -->
	  <div class="space-y-8">

		<div>
		  <h3 class="font-heading text-2xl text-charcoal mb-6">
			Kontaktinformationen
		  </h3>

		  <!-- Contact Cards -->
		  <div class="space-y-4">

			<!-- Email -->
			<div class="flex items-start gap-4 p-4 bg-sage/20 rounded-xl hover:bg-sage/30 transition-smooth">
			  <div class="flex-shrink-0 w-12 h-12 bg-olive/30 rounded-full flex items-center justify-center">
				<svg class="w-6 h-6 text-olive" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
				</svg>
			  </div>
			  <div>
				<p class="font-medium text-charcoal mb-1">E-Mail</p>
				<a href="mailto:info@tierpsychologie-nw.com" class="text-olive hover:underline">
				  info@tierpsychologie-nw.com
				</a>
			  </div>
			</div>

			<!-- Phone -->
			<div class="flex items-start gap-4 p-4 bg-sage/20 rounded-xl hover:bg-sage/30 transition-smooth">
			  <div class="flex-shrink-0 w-12 h-12 bg-olive/30 rounded-full flex items-center justify-center">
				<svg class="w-6 h-6 text-olive" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
				</svg>
			  </div>
			  <div>
				<p class="font-medium text-charcoal mb-1">Telefon</p>
				<a href="tel:+4915256323643" class="text-olive hover:underline">
				  +49 152 56323643
				</a>
			  </div>
			</div>

			<!-- Location -->
			<div class="flex items-start gap-4 p-4 bg-sage/20 rounded-xl hover:bg-sage/30 transition-smooth">
			  <div class="flex-shrink-0 w-12 h-12 bg-olive/30 rounded-full flex items-center justify-center">
				<svg class="w-6 h-6 text-olive" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
				</svg>
			  </div>
			  <div>
				<p class="font-medium text-charcoal mb-1">Standort</p>
				<p class="text-charcoal/70">Osnabrück, Niedersachsen</p>
			  </div>
			</div>

		  </div>
		</div>

		<!-- Opening Hours -->
		<div class="bg-white rounded-2xl p-8 shadow-lg">
		  <h4 class="font-heading text-xl text-charcoal mb-4">Beratungszeiten</h4>
		  <div class="space-y-2 text-charcoal/70">
			<div class="flex justify-between">
			  <span>Telefonisch</span>
			  <span class="font-medium text-olive">Außer Mittwochs</span>
			</div>
			<div class="flex justify-between">
			  <span>E-Mail/Whatsapp</span>
			  <span class="font-medium text-olive">Immer</span>
			</div>
			<div class="flex justify-between">
			  <span>Besuche vor Ort</span>
			  <span class="font-medium text-charcoal/50">Nach Vereinbarung</span>
			</div>
		  </div>
		</div>

	  </div>

	  <!-- Contact Form -->
	  <div class="bg-white rounded-2xl p-8 md:p-10 shadow-xl">

		<form action="https://formspree.io/f/mjgdolqj" method="POST" class="space-y-6">

		  <!-- Name -->
		  <div>
			<label for="name" class="block text-sm font-medium text-charcoal mb-2">
			  Name *
			</label>
			<input
			  type="text"
			  id="name"
			  name="name"
			  required
			  class="w-full px-4 py-3 border-2 border-sage/30 rounded-lg focus:border-olive focus:outline-none transition-smooth"
			  placeholder="Ihr Name"
			/>
		  </div>

		  <!-- Email -->
		  <div>
			<label for="email" class="block text-sm font-medium text-charcoal mb-2">
			  E-Mail *
			</label>
			<input
			  type="email"
			  id="email"
			  name="email"
			  required
			  class="w-full px-4 py-3 border-2 border-sage/30 rounded-lg focus:border-olive focus:outline-none transition-smooth"
			  placeholder="ihre@email.de"
			/>
		  </div>

		  <!-- Phone -->
		  <div>
			<label for="phone" class="block text-sm font-medium text-charcoal mb-2">
			  Telefon
			</label>
			<input
			  type="tel"
			  id="phone"
			  name="phone"
			  class="w-full px-4 py-3 border-2 border-sage/30 rounded-lg focus:border-olive focus:outline-none transition-smooth"
			  placeholder="+49 123 456 789"
			/>
		  </div>

		  <!-- Animal Type -->
		  <div>
			<label for="animal" class="block text-sm font-medium text-charcoal mb-2">
			  Tierart *
			</label>
			<select
			  id="animal"
			  name="animal"
			  required
			  class="w-full px-4 py-3 border-2 border-sage/30 rounded-lg focus:border-olive focus:outline-none transition-smooth bg-white"
			>
			  <option value="">Bitte wählen</option>
			  <option value="hund">Hund</option>
			  <option value="katze">Katze</option>
			  <option value="pferd">Pferd</option>
			  <option value="andere">Andere</option>
			</select>
		  </div>

		  <!-- Message -->
		  <div>
			<label for="message" class="block text-sm font-medium text-charcoal mb-2">
			  Ihre Nachricht *
			</label>
			<textarea
			  id="message"
			  name="message"
			  required
			  rows="5"
			  class="w-full px-4 py-3 border-2 border-sage/30 rounded-lg focus:border-olive focus:outline-none transition-smooth resize-none"
			  placeholder="Beschreiben Sie kurz Ihr Anliegen..."
			></textarea>
		  </div>

		  <!-- Privacy -->
		  <div class="flex items-start gap-3">
			<input
			  type="checkbox"
			  id="privacy"
			  name="privacy"
			  required
			  class="mt-1 w-4 h-4 text-olive border-sage/30 rounded focus:ring-olive"
			/>
			<label for="privacy" class="text-sm text-charcoal/70">
			  Ich habe die Datenschutzerklärung zur Kenntnis genommen und 
			  bin damit einverstanden, dass meine Daten zur Bearbeitung 
			  meiner Anfrage gespeichert werden.*
			</label>
		  </div>

		  <!-- Submit Button -->
		  <button type="submit" class="btn-primary w-full">
			Nachricht senden
		  </button>

		  <p class="text-xs text-charcoal/60 text-center">
			* Pflichtfelder
		  </p>

		</form>

	  </div>

	</div>

  </div>
</section>
