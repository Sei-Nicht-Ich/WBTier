---
// Service Icon Bubble - Kleine runde Bild-Bubble für Service-Cards
interface Props {
  imagePath?: string;
  fallbackEmoji: string;
  alt: string;
  size?: 'small' | 'medium' | 'large';
}

const { imagePath, fallbackEmoji, alt, size = 'medium' } = Astro.props;

const sizeClasses = {
  small: 'w-12 h-12',
  medium: 'w-16 h-16',
  large: 'w-20 h-20'
};
---

<div class={`service-icon-bubble ${sizeClasses[size]} relative group`}>
  {imagePath ? (
	<img 
	  src={imagePath} 
	  alt={alt}
	  class="w-full h-full object-cover"
	/>
  ) : (
	<div class="bubble-placeholder">
	  <span class="text-2xl">{fallbackEmoji}</span>
	</div>
  )}
</div>

<style>
  .service-icon-bubble {
	border-radius: 50%;
	overflow: hidden;
	box-shadow: 0 4px 12px rgba(58, 58, 58, 0.1);
	border: 2px solid rgba(183, 190, 165, 0.3);
	transition: all 0.3s ease;
	flex-shrink: 0;
  }

  .service-icon-bubble:hover {
	transform: scale(1.1);
	box-shadow: 0 6px 20px rgba(183, 190, 165, 0.3);
  }

  .bubble-placeholder {
	width: 100%;
	height: 100%;
	background: linear-gradient(135deg, rgba(220, 230, 200, 0.5), rgba(183, 190, 165, 0.5));
	display: flex;
	align-items: center;
	justify-content: center;
  }

  .service-icon-bubble img {
	transition: transform 0.3s ease;
  }

  .service-icon-bubble:hover img {
	transform: scale(1.1);
  }
</style>
