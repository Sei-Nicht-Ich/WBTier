---
// Hero Section - Eindrucksvoller Einstieg
---

<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden">

  <!-- Background Gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-sage/30 via-cream to-olive/20"></div>

  <!-- Decorative Elements -->
  <div class="absolute top-20 right-10 w-72 h-72 bg-sage/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-10 w-96 h-96 bg-olive/10 rounded-full blur-3xl"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 py-20 text-center">

	<!-- Subtitle -->
	<p class="text-olive uppercase tracking-widest text-sm md:text-base font-medium mb-6 animate-fade-in">
	  Vertrauen • Verständnis • Verbindung
	</p>

	<!-- Main Heading -->
	<h1 class="font-heading text-5xl md:text-7xl lg:text-8xl text-charcoal mb-8 leading-tight animate-fade-in">
	  Tierpsychologische<br />
	  <span class="text-gradient">Beratung</span>
	</h1>

	<!-- Description -->
	<p class="text-lg md:text-xl text-charcoal/80 max-w-3xl mx-auto mb-12 leading-relaxed animate-fade-in">
	  Ihr Tier verdient es verstanden zu werden. Gemeinsam finden wir 
	  Lösungen für Verhaltensprobleme und stärken die Bindung zwischen 
	  Ihnen und Ihrem tierischen Begleiter.
	</p>

	<!-- CTA Buttons -->
	<div class="flex flex-col sm:flex-row gap-6 justify-center items-center animate-fade-in">
	  <a href="#contact" class="btn-primary w-full sm:w-auto">
		Beratung anfragen
	  </a>
	  <a href="#services" class="btn-secondary w-full sm:w-auto">
		Leistungen ansehen
	  </a>
	</div>

	<!-- Trust Indicators -->
	<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-20 max-w-4xl mx-auto">

	  <div class="flex flex-col items-center animate-slide-in">
		<div class="text-4xl mb-3">🐕</div>
		<h3 class="font-heading text-xl text-charcoal mb-2">Hunde</h3>
		<p class="text-charcoal/70 text-sm">Verhaltensanalyse & Training</p>
	  </div>

	  <div class="flex flex-col items-center animate-slide-in" style="animation-delay: 0.1s;">
		<div class="text-4xl mb-3">🐱</div>
		<h3 class="font-heading text-xl text-charcoal mb-2">Katzen</h3>
		<p class="text-charcoal/70 text-sm">Problemverhalten lösen</p>
	  </div>

	  <div class="flex flex-col items-center animate-slide-in" style="animation-delay: 0.2s;">
		<div class="text-4xl mb-3">🐴</div>
		<h3 class="font-heading text-xl text-charcoal mb-2">Pferde</h3>
		<p class="text-charcoal/70 text-sm">Beziehungsarbeit & Vertrauen</p>
	  </div>

	</div>

  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce">
	<a href="#about" class="text-olive hover:text-charcoal transition-smooth" aria-label="Nach unten scrollen">
	  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
	  </svg>
	</a>
  </div>

</section>
