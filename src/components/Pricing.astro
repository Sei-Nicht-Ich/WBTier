---
// Pricing Section - Preisübersicht
---

<section id="pricing" class="section-padding bg-gradient-to-br from-sage/20 via-cream to-olive/10">
  <div class="max-w-7xl mx-auto">

	<!-- Section Header -->
	<div class="text-center mb-8">
	  <p class="text-olive uppercase tracking-widest text-sm font-medium mb-4">
		Preise & Leistungen
	  </p>
	  <h2 class="font-heading text-4xl md:text-5xl text-charcoal mb-6">
		Transparente <span class="text-olive">Preisgestaltung</span>
	  </h2>
	  <p class="text-charcoal/70 text-lg max-w-2xl mx-auto">
		Individuelle Beratung und Training – faire Preise für nachhaltige Erfolge
	  </p>
	</div>

	<!-- Studium Hinweis -->
	<div class="bg-olive/10 border-l-4 border-olive rounded-lg p-6 mb-12 max-w-4xl mx-auto">
	  <p class="text-charcoal/80 text-center">
		<span class="font-medium text-olive">Aktuelle Studienpreise:</span> Die folgenden Preise gelten während meines Studiums. Nach Abschluss werden die Preise marktüblich angepasst.
	  </p>
	</div>

	<!-- Pricing Grid -->
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">

	  <!-- Akute Verhaltensanalyse -->
	  <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-smooth border-2 border-transparent hover:border-sage">
		<div class="text-center mb-6">
		  <h3 class="font-heading text-2xl text-charcoal mb-4">Akute Verhaltensanalyse</h3>

		  <!-- Erster Termin -->
		  <div class="mb-2 pb-2 border-b border-sage/20">
			<p class="text-charcoal/60 text-sm mb-3">Erster Termin (60–90 Min)</p>
			<div class="text-xl font-bold text-olive">
			  <div class="flex flex-col gap-1">
				<span>Hund: 50 €</span>
				<span>Katze: 45 €</span>
				<span>Pferd: 80 €</span>
			  </div>
			</div>
		  </div>

		  <!-- Folgetermine -->
		  <div>
			<p class="text-charcoal/60 text-sm mb-3">Folgetermine (45–60 Min)</p>
			<div class="text-xl font-bold text-olive">
			  <div class="flex flex-col gap-1">
				<span>Hund: 30 €</span>
				<span>Katze: 25 €</span>
				<span>Pferd: 55 €</span>
			  </div>
			</div>
		  </div>
		</div>

		<ul class="space-y-3">
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Ausführliche Anamnese (vor Ort oder Online)</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Verhaltensanalyse vor Ort</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Inklusive Trainingsplan & Online-Support</span>
		  </li>
		</ul>
	  </div>

	  <!-- Regelmäßiges Training Pferd -->
	  <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-smooth border-2 border-sage relative">
		<div class="text-center mb-6">
		  <h3 class="font-heading text-2xl text-charcoal mb-2">Regelmäßiges Training Pferd</h3>
		  <p class="text-charcoal/60 text-sm mb-4">2–4x pro Monat</p>
		  <p class="text-charcoal/60 text-sm mb-3">Einzeltraining (30–60 Min)</p>
		  <div class="text-xl font-bold text-olive">25–30 €</div>
		</div>
		<div class="bg-sage/10 rounded-lg p-3 text-center">
		  <p class="text-charcoal/60 text-sm mb-3">Gruppentraining (2-5 Teilnehmer)</p>
		  <div class="text-xl font-bold text-olive">15–20 €</div>
		</div>
		<ul class="space-y-3 mb-6">
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Praktisches Training (30 - 60 Minuten)</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Bodenarbeit, Longe, Reiten</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Übungen für das eigene Training</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Inklusive Trainingsplan & Online-Support</span>
		  </li>
		</ul>
	  </div>

	  <!-- Haltungsberatung -->
	  <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-smooth border-2 border-transparent hover:border-sage">
		<div class="text-center mb-6">
		  <h3 class="font-heading text-2xl text-charcoal mb-2">Haltungsberatung</h3>
		  <p class="text-charcoal/60 text-sm mb-4">60–90 Minuten</p>
		  <div class="text-xl font-bold text-olive">40 €</div>
		</div>
		<ul class="space-y-3">
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Optimierung der Haltung</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Artgerechte Umgebung</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Praktische Tipps</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Individuelle Empfehlungen</span>
		  </li>
		</ul>
	  </div>

	  <!-- Kaufberatung -->
	  <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-smooth border-2 border-transparent hover:border-sage">
		<div class="text-center mb-6">
		  <h3 class="font-heading text-2xl text-charcoal mb-2">Kaufberatung</h3>
		  <p class="text-charcoal/60 text-sm mb-4">Vor dem Tierkauf</p>
		  <div class="text-xl font-bold text-olive">
			<div class="flex flex-col gap-1">
			  <span>Analyse: 30–45 €</span>
			  <span>Begleitung: 45–65 €</span>
			</div>
		  </div>
		</div>
		<ul class="space-y-3">
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Bedarfsanalyse</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Empfehlung passender Tiere</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Begleitung vor Ort möglich</span>
		  </li>
		  <li class="flex items-start gap-2">
			<svg class="w-5 h-5 text-olive flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
			  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
			</svg>
			<span class="text-sm text-charcoal/80">Professionelle Einschätzung</span>
		  </li>
		</ul>
	  </div>

	  <!-- Notfall-Termin wird nicht mehr angezeigt - nicht in Screenshots -->
	</div>

	<!-- Zusatzinfo & Anfahrt -->
	<div class="bg-white rounded-2xl p-8 shadow-lg max-w-4xl mx-auto mt-16">
	  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

		<!-- Anfahrt -->
		<div>
		  <h4 class="font-heading text-xl text-charcoal mb-4 flex items-center gap-2">
			<svg class="w-6 h-6 text-olive" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
			</svg>
			Anfahrt
		  </h4>
		  <ul class="space-y-2 text-charcoal/80 text-sm">
			<li class="flex items-start gap-2">
			  <span class="text-olive">•</span>
			  <span>Im Umkreis von <strong>10 km kostenfrei</strong></span>
			</li>
			<li class="flex items-start gap-2">
			  <span class="text-olive">•</span>
			  <span>Darüber hinaus: <strong>0,50€ pro km</strong></span>
			</li>
			<li class="flex items-start gap-2">
			  <span class="text-olive">•</span>
			  <span>Mobiles Training im gesamten Raum verfügbar</span>
			</li>
		  </ul>
		</div>

		<!-- Zahlungsinfo -->
		<div>
		  <h4 class="font-heading text-xl text-charcoal mb-4 flex items-center gap-2">
			<svg class="w-6 h-6 text-olive" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
			</svg>
			Zahlung & Konditionen
		  </h4>
		  <ul class="space-y-2 text-charcoal/80 text-sm">
			<li class="flex items-start gap-2">
			  <span class="text-olive">•</span>
			  <span>Barzahlung vor Ort oder Überweisung</span>
			</li>
			<li class="flex items-start gap-2">
			  <span class="text-olive">•</span>
			  <span>Alle Preise inkl. MwSt.</span>
			</li>
			<li class="flex items-start gap-2">
			  <span class="text-olive">•</span>
			  <span>Absagen bis 24h vorher kostenfrei</span>
			</li>
			<li class="flex items-start gap-2">
			  <span class="text-olive">•</span>
			  <span><strong>15 Min. kostenloses</strong> Kennenlerngespräch am Telefon</span>
			</li>
		  </ul>
		</div>

	  </div>
	</div>

	<!-- CTA -->
	<div class="text-center mt-12">
	  <p class="text-charcoal/70 mb-6">
		Unsicher, welches Angebot das richtige ist? Lassen Sie uns darüber sprechen!
	  </p>
	  <a 
		href="#contact" 
		class="inline-block bg-olive hover:bg-olive/90 text-white font-medium px-8 py-4 rounded-full transition-smooth shadow-lg hover:shadow-xl"
	  >
		Jetzt kostenloses Erstgespräch vereinbaren
	  </a>
	</div>

  </div>
</section>
