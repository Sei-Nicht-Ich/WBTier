---
interface Props {
  imagePath?: string;
  fallbackEmoji?: string;
  size?: 'small' | 'medium' | 'large' | 'xlarge';
  position?: 'left' | 'right' | 'center';
}

const { 
  imagePath, 
  fallbackEmoji = '🐾', 
  size = 'medium',
  position = 'center'
} = Astro.props;

const sizeClasses = {
  small: 'w-24 h-24',
  medium: 'w-40 h-40',
  large: 'w-52 h-52',
  xlarge: 'w-64 h-64'
};
---

<div class={`decorative-bubble ${sizeClasses[size]}`}>
  {imagePath ? (
    <img src={imagePath} alt="Dekoratives Tierbild" />
  ) : (
    <div class="bubble-placeholder">
      <span class="emoji-icon">{fallbackEmoji}</span>
    </div>
  )}
</div>

<style>
  .decorative-bubble {
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(58, 58, 58, 0.15);
    border: 4px solid rgba(183, 190, 165, 0.4);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .decorative-bubble:hover {
    transform: scale(1.08) rotate(3deg);
    box-shadow: 0 20px 50px rgba(183, 190, 165, 0.35);
    border-color: rgba(183, 190, 165, 0.6);
  }

  .decorative-bubble img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .decorative-bubble:hover img {
    transform: scale(1.15);
  }

  .bubble-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(220, 230, 200, 0.6), rgba(183, 190, 165, 0.6));
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(5px);
  }

  .emoji-icon {
    font-size: 3rem;
  }

  @media (max-width: 768px) {
    .decorative-bubble {
      width: 80px !important;
      height: 80px !important;
      border-width: 3px;
    }

    .emoji-icon {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .decorative-bubble {
      width: 60px !important;
      height: 60px !important;
      border-width: 2px;
    }

    .emoji-icon {
      font-size: 1.5rem;
    }
  }
</style>